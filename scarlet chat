-- ── Resize ────────────────────────────────────────────────────────
grip.MouseButton1Down:Connect(function()
    resizing = true
    resizeStartX = mouse.X
    resizeStartY = mouse.Y
    resizeStartW = frame.AbsoluteSize.X
    resizeStartH = frame.AbsoluteSize.Y
end)

-- ── RenderStepped: drag + resize ──────────────────────────────────
RunService.RenderStepped:Connect(function()
    if tbDragging then
        local vp = workspace.CurrentCamera.ViewportSize
        local nx = math.max(0, math.min(mouse.X - tbDragOffX, vp.X - toggleBtn.AbsoluteSize.X))
        local ny = math.max(0, math.min(mouse.Y - tbDragOffY, vp.Y - toggleBtn.AbsoluteSize.Y))
        toggleBtn.Position = UDim2.new(0, nx, 0, ny)
    end
    if dragging then
        local vp = workspace.CurrentCamera.ViewportSize
        local nx = clamp(mouse.X - dragOffX, 0, vp.X - frame.AbsoluteSize.X)
        local ny = clamp(mouse.Y - dragOffY, 0, vp.Y - frame.AbsoluteSize.Y)
        frame.Position = UDim2.new(0, nx, 0, ny)
    end
    if resizing and not isMinimized then
        local nw = clamp(resizeStartW + (mouse.X - resizeStartX), MIN_W, MAX_W)
        local nh = clamp(resizeStartH + (mouse.Y - resizeStartY), MIN_H, MAX_H)
        frame.Size = UDim2.new(0, nw, 0, nh)
        savedHeight = nh
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        resizing = false
    end
end)

