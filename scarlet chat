-- ── Add message ───────────────────────────────────────────────────
local function addMessage(sender, text, timestamp, isSelf, isSystem)
    messageCount += 1
    if messageCount > MAX_MESSAGES then
        for _, c in ipairs(scrollFrame:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextLabel") then
                c:Destroy(); break
            end
        end
    end

    if isSystem then
        local lbl = Instance.new("TextLabel", scrollFrame)
        lbl.Size = UDim2.new(1, 0, 0, 18)
        lbl.BackgroundTransparency = 1
        lbl.Text = "─  " .. text .. "  ─"
        lbl.TextColor3 = Color3.fromRGB(80, 80, 115)
        lbl.TextSize = 10
        lbl.Font = Enum.Font.Gotham
        lbl.TextXAlignment = Enum.TextXAlignment.Center
        lbl.LayoutOrder = messageCount
        lbl.ZIndex = 2
    else
        local timeStr = ""
        if timestamp then
            local h, m = timestamp:match("T(%d+):(%d+)")
            if h and m then timeStr = h .. ":" .. m end
        end

        local bubble = Instance.new("Frame", scrollFrame)
        bubble.Size = UDim2.new(0.78, 0, 0, 0)
        bubble.AutomaticSize = Enum.AutomaticSize.Y
        bubble.BackgroundColor3 = isSelf
            and Color3.fromRGB(75, 75, 195)
            or  Color3.fromRGB(25, 25, 40)
        bubble.BorderSizePixel = 0
        bubble.LayoutOrder = messageCount
        bubble.ZIndex = 2
        if isSelf then bubble.Position = UDim2.new(0.22, 0, 0, 0) end
        Instance.new("UICorner", bubble).CornerRadius = UDim.new(0, 10)

        local bs = Instance.new("UIStroke", bubble)
        bs.Color = isSelf and Color3.fromRGB(105,105,235) or Color3.fromRGB(45,45,68)
        bs.Thickness = 1

        local pad = Instance.new("UIPadding", bubble)
        pad.PaddingLeft   = UDim.new(0, 9)
        pad.PaddingRight  = UDim.new(0, 9)
        pad.PaddingTop    = UDim.new(0, 6)
        pad.PaddingBottom = UDim.new(0, 6)

        local bll = Instance.new("UIListLayout", bubble)
        bll.SortOrder = Enum.SortOrder.LayoutOrder
        bll.Padding = UDim.new(0, 2)

        local meta = Instance.new("TextLabel", bubble)
        meta.Size = UDim2.new(1, 0, 0, 13)
        meta.BackgroundTransparency = 1
        meta.Text = sender .. (timeStr ~= "" and ("  " .. timeStr) or "")
        meta.TextColor3 = isSelf
            and Color3.fromRGB(165, 163, 255)
            or  Color3.fromRGB(115, 115, 155)
        meta.TextSize = 10
        meta.Font = Enum.Font.Gotham
        meta.TextXAlignment = Enum.TextXAlignment.Left
        meta.LayoutOrder = 1
        meta.ZIndex = 3

        local msg = Instance.new("TextLabel", bubble)
        msg.Size = UDim2.new(1, 0, 0, 0)
        msg.AutomaticSize = Enum.AutomaticSize.Y
        msg.BackgroundTransparency = 1
        msg.Text = text
        msg.TextColor3 = Color3.fromRGB(225, 225, 248)
        msg.TextSize = 13
        msg.Font = Enum.Font.Gotham
        msg.TextWrapped = true
        msg.TextXAlignment = Enum.TextXAlignment.Left
        msg.LayoutOrder = 2
        msg.ZIndex = 3
    end

    scrollToBottom()

    if not isOpen and not isSystem then
        unreadCount += 1
        badge.Text = tostring(unreadCount)
        badge.Visible = true
        tw(toggleBtn, {BackgroundColor3 = Color3.fromRGB(130, 55, 210)})
        task.delay(0.35, function()
            tw(toggleBtn, {BackgroundColor3 = Color3.fromRGB(91, 91, 214)})
        end)
    end
end

-- ── Minimize ──────────────────────────────────────────────────────
local savedHeight = DEF_H
local function setMinimized(v)
    isMinimized = v
    if v then
        savedHeight = frame.AbsoluteSize.Y
        tw(frame, {Size = UDim2.new(0, frame.AbsoluteSize.X, 0, 46)})
        scrollFrame.Visible  = false
        inputArea.Visible    = false
        grip.Visible         = false
        minimizeBtn.Text     = "▲"
    else
        tw(frame, {Size = UDim2.new(0, frame.AbsoluteSize.X, 0, savedHeight)})
        scrollFrame.Visible  = true
        inputArea.Visible    = true
        grip.Visible         = true
        minimizeBtn.Text     = "—"
        scrollToBottom()
    end
end

minimizeBtn.MouseButton1Click:Connect(function() setMinimized(not isMinimized) end)

-- ── Open / close ──────────────────────────────────────────────────
local function openChat()
    isOpen = true
    frame.Visible = true
    unreadCount = 0
    badge.Visible = false
    toggleBtn.Text = "Close"
    tw(toggleBtn, {BackgroundColor3 = Color3.fromRGB(155, 45, 45)})
    task.delay(0.1, scrollToBottom)
    task.defer(function() inputBox:CaptureFocus() end)
end

local function closeChat()
    isOpen = false
    frame.Visible = false
    toggleBtn.Text = "Chat"
    tw(toggleBtn, {BackgroundColor3 = Color3.fromRGB(91, 91, 214)})
end

toggleBtn.MouseButton1Click:Connect(function()
    if isOpen then closeChat() else openChat() end
end)
closeBtn.MouseButton1Click:Connect(closeChat)

