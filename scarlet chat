addHover(closeBtn,    Color3.fromRGB(170,45,45),   Color3.fromRGB(215,55,55))

-- ── Send message ──────────────────────────────────────────────────
local function sendMessage()
    local text = inputBox.Text
    if text == "" or text:match("^%s*$") or not socket then return end
    local ok, payload = pcall(HttpService.JSONEncode, HttpService, {
        sender = player.Name, text = text
    })
    if ok then
        socket:Send(payload)
        inputBox.Text = ""
    end
end

sendBtn.MouseButton1Click:Connect(sendMessage)
inputBox.FocusLost:Connect(function(enter) if enter then sendMessage() end end)

-- ── WebSocket ─────────────────────────────────────────────────────
local function connect()
    statusLabel.Text = "Connecting..."
    statusLabel.TextColor3 = Color3.fromRGB(200, 160, 40)
    dot.BackgroundColor3 = Color3.fromRGB(200, 160, 40)

    local ok, ws = pcall(WebSocket.connect, SERVER_URL)
    if not ok then
        task.delay(5, connect)
        return
    end

    socket = ws
    setStatus(true)

    ws.OnMessage:Connect(function(raw)
        local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
        if not ok2 or not data then return end

        if data.type == "history" then
            for _, m in ipairs(data.messages) do
                if m.type == "message" then
                    addMessage(m.sender, m.text, m.timestamp, m.sender == player.Name, false)
                end
            end
            scrollToBottom()
        elseif data.type == "message" then
            addMessage(data.sender, data.text, data.timestamp, data.sender == player.Name, false)
        elseif data.type == "system" then
            addMessage("", data.text, nil, false, true)
        end
    end)

    ws.OnClose:Connect(function()
        socket = nil
        setStatus(false)
        task.delay(5, connect)
    end)
end

-- ── Go ────────────────────────────────────────────────────────────
connect()
